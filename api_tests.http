}


# ════════════════════════════════════════════════════════
# BUSINESS MODEL CANVAS   prefix: /api/v1/bmc
# ════════════════════════════════════════════════════════

### Generate BMC
POST {{baseUrl}}/api/v1/bmc/generate
Content-Type: application/json

{
  "idea_name": "FinBoost",
  "idea_description": "AI-powered credit scoring for Egyptian SMEs",
  "region": "MENA",
  "market_research": {
    "data": {
      "market_size": "$3B",
      "competitors": ["Khazna", "Telda"],
      "trends": ["Open banking", "Digital lending"]
    }
  },
  "evaluation": null,
  "recommendation": null
}

### ✅ Enhance Existing BMC (WORKING)
POST {{baseUrl}}/api/v1/bmc/enhance
Content-Type: application/json

{
  "idea_name": "FinBoost",
  "idea_description": "AI credit scoring for SMEs",
  "region": "MENA",
  "current_bmc": {
    "value_proposition": ["Fast credit decisions for SMEs"],
    "customer_segments": ["Cairo grocery retailers"],
    "revenue_streams": ["2% transaction fee"],
    "channels": ["Direct sales"],
    "customer_relationships": ["Account managers"],
    "key_resources": ["Credit scoring model"],
    "key_activities": ["Loan processing"],
    "key_partnerships": ["Fawry payment network"],
    "cost_structure": ["Cloud infrastructure $2k/mo"]
  },
  "document_changes": ["Add enterprise B2B tier", "Expand to Saudi Arabia"]
}


# ════════════════════════════════════════════════════════
# DOCUMENT CHAT   prefix: /api/v1/document-chat
# ════════════════════════════════════════════════════════
# NOTE: file_path must be a real local file path OR a URL.
# For local testing, pass a JSON string as file_path.

### Chat with Document (JSON payload as file_path)
POST {{baseUrl}}/api/v1/document-chat/test-document-qa
Content-Type: application/json

{
  "file_path": "{\"company_name\": \"FinBoost\", \"problem\": \"SMEs cannot get loans\", \"solution\": \"AI credit scoring\", \"market\": \"Egypt Fintech\"}",
  "query": "What problem does this startup solve?",
  "provider": "groq",
  "chat_history": [],
  "document_type": "pitch_deck"
}


# ════════════════════════════════════════════════════════
# CHAT SUMMARIZER   prefix: /api/v1/chat-summarizer
# NOTE: needs valid GROQ_API_KEY in .env to work
# ════════════════════════════════════════════════════════

### Summarize Chat to Extract Document Changes
POST {{baseUrl}}/api/v1/chat-summarizer/summarize
Content-Type: application/json

{
  "messages": [
    { "role": "user",      "content": "What should I focus on for my GTM strategy?" },
    { "role": "assistant", "content": "Focus on direct outbound sales to Cairo SMEs first." },
    { "role": "user",      "content": "Can you add a section about our unit economics?" },
    { "role": "assistant", "content": "Sure, I can add a unit economics section showing CAC and LTV." },
    { "role": "user",      "content": "Also update the market size to include Saudi Arabia." }
  ]
}


# ════════════════════════════════════════════════════════
# FEED RECOMMENDATION   prefix: /api/v1/feed
# ════════════════════════════════════════════════════════

### ✅ Get Investor Subtags (WORKING)
GET {{baseUrl}}/api/v1/feed/investors/user123/subtags?limit=10

### Get Recommended Pitchdecks for Investor (full LangGraph pipeline)
GET {{baseUrl}}/api/v1/feed/recommend/investor_001

### Get Similar Investors
GET {{baseUrl}}/api/v1/feed/similar-investors/investor_001?k=5

### Record Interaction — LIKE (use a real pitchdeck UUID from your DB)
POST {{baseUrl}}/api/v1/feed/interactions
Content-Type: application/json

{
  "user_id": "6622ce4d-2f0d-4791-9b80-867d69e6c9a9",
  "pitch_id": "0011b18a-1806-46be-b144-01a1eecb519d",
  "liked": true,
  "contacted": false
}

### Record Interaction — DISLIKE
POST {{baseUrl}}/api/v1/feed/interactions
Content-Type: application/json

{
  "user_id": "6622ce4d-2f0d-4791-9b80-867d69e6c9a9",
  "pitch_id": "0011b18a-1806-46be-b144-01a1eecb519d",
  "liked": false,
  "contacted": false
}

### Record Interaction — CONTACT
POST {{baseUrl}}/api/v1/feed/interactions
Content-Type: application/json

{
  "user_id": "6622ce4d-2f0d-4791-9b80-867d69e6c9a9",
  "pitch_id": "0011b18a-1806-46be-b144-01a1eecb519d",
  "liked": false,
  "contacted": true
}

### Build Sub-Vectors for Investor
POST {{baseUrl}}/api/v1/feed/sub-vectors/build/investor_001

### Sync Neo4j (background task)
POST {{baseUrl}}/api/v1/feed/admin/sync-neo4j

### Supabase Webhook — Investor Updated
POST {{baseUrl}}/api/v1/feed/webhook/investor
Content-Type: application/json

{
  "type": "UPDATE",
  "record": { "user_id": "6622ce4d-2f0d-4791-9b80-867d69e6c9a9" }
}

### Supabase Webhook — Pitchdeck Updated
POST {{baseUrl}}/api/v1/feed/webhook/pitchdeck
Content-Type: application/json

{
  "type": "INSERT",
  "record": { "pitchdeckid": "0011b18a-1806-46be-b144-01a1eecb519d" }
}


# ════════════════════════════════════════════════════════
# VECTOR DB ADMIN   prefix: /api/v1/feed
# ════════════════════════════════════════════════════════

### ✅ VDB Health Check (WORKING)
GET {{baseUrl}}/api/v1/feed/health

### Initialize Qdrant Collections
POST {{baseUrl}}/api/v1/feed/collections/init

### Batch Sync All Investor Embeddings → Qdrant
POST {{baseUrl}}/api/v1/feed/investor-embedding/batch

### Sync Single Investor Embedding
POST {{baseUrl}}/api/v1/feed/investor-embedding
Content-Type: application/json

{
  "investor_id": "6622ce4d-2f0d-4791-9b80-867d69e6c9a9"
}

### Batch Sync All Pitchdeck Embeddings → Qdrant
POST {{baseUrl}}/api/v1/feed/pitchdeck-embedding/batch

### Sync Single Pitchdeck Embedding
POST {{baseUrl}}/api/v1/feed/pitchdeck-embedding
Content-Type: application/json

{
  "pitchdeck_id": "0011b18a-1806-46be-b144-01a1eecb519d"
}

### Sync Neo4j (VDB Admin route)
POST {{baseUrl}}/api/v1/feed/neo4j/sync

### ⚠️ Verify Supabase ↔ Neo4j Sync (requires NEO4J_URI configured)
GET {{baseUrl}}/api/v1/feed/admin/verify-sync

### ⚠️ DANGER: Delete All Qdrant Collections
DELETE {{baseUrl}}/api/v1/feed/collections


# ════════════════════════════════════════════════════════
# PITCH ANALYZER   prefix: /api/v1/pitch-analyzer
# ════════════════════════════════════════════════════════

### ✅ Check Environment Variables (WORKING)
GET {{baseUrl}}/api/v1/pitch-analyzer/env-check

### ✅ Check Worker Status (WORKING)
GET {{baseUrl}}/api/v1/pitch-analyzer/worker-status

### Get Last Generated Report
GET {{baseUrl}}/api/v1/pitch-analyzer/get-report

### Run LLM Pre-flight Extraction
POST {{baseUrl}}/api/v1/pitch-analyzer/extract
Content-Type: application/json

{
  "transcript": "Hi, I am Ahmed. We built FinBoost, an AI credit scoring platform for SMEs in Egypt.",
  "context": {}
}

### Generate Investment Readiness Report
POST {{baseUrl}}/api/v1/pitch-analyzer/generate-report
Content-Type: application/json

{
  "transcript": "FinBoost solves credit access for Egyptian SMEs using AI-based scoring.",
  "session_id": "test-session-001"
}

### Start LiveKit AI Agent Worker
POST {{baseUrl}}/api/v1/pitch-analyzer/start

### Stop LiveKit AI Agent Worker
POST {{baseUrl}}/api/v1/pitch-analyzer/stop

### Generate LiveKit Token
POST {{baseUrl}}/api/v1/pitch-analyzer/token
Content-Type: application/json

{
  "room_name": "test-room",
  "participant_name": "founder_ahmed"
}


