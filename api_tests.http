### ✅ Health Check
GET {{baseUrl}}/


# ════════════════════════════════════════════════════════
# PDF EXTRACTION   prefix: /api/v1/pdf
# ════════════════════════════════════════════════════════
# NOTE: This endpoint uses multipart/form-data (file upload),
#       not JSON. Use Swagger UI at http://localhost:8000/docs
#       to upload a real .pdf file for this one.
# Direct REST Client test shown for reference only:
#
### Upload a PDF file (use Swagger /docs for this)
# POST {{baseUrl}}/api/v1/pdf/extract-from-pdf
# Content-Type: multipart/form-data; boundary=boundary
#
# --boundary
# Content-Disposition: form-data; name="file"; filename="pitch.pdf"
# Content-Type: application/pdf
#
# < ./your_pitch_deck.pdf
# --boundary--


# ════════════════════════════════════════════════════════
# EVALUATION   prefix: /api/v1/evaluation
# ════════════════════════════════════════════════════════

### Start Evaluation (background job — returns job_id immediately)
POST {{baseUrl}}/api/v1/evaluation/evaluate/all
Content-Type: application/json

{
  "data": {
    "company_snapshot": {
      "company_name": "FinBoost",
      "location": "Egypt",
      "industry": "Fintech",
      "current_stage": "Pre-Seed",
      "current_round": { "target_amount": "$500k" }
    },
    "problem_definition": {
      "problem_statement": "SMEs in Egypt cannot access working capital from traditional banks.",
      "frequency": "Daily",
      "gap_analysis": "Banks ignore digital-native SMEs without collateral."
    },
    "founder_and_team": {
      "founders": [
        {
          "name": "Ahmed Hassan",
          "role": "CEO",
          "prior_experience": "Ex-CIB banker",
          "years_direct_experience": 8,
          "founder_market_fit_statement": "I watched SMEs get rejected for 8 years."
        }
      ]
    },
    "product_and_solution": {
      "differentiation": "Real-time API-based credit scoring",
      "core_stickiness": "Embedded VAT filing reduces churn"
    },
    "traction_metrics": {
      "active_users_monthly": 120,
      "early_revenue": "EGP 60,000"
    },
    "market_and_scope": {
      "beachhead_market": "Cairo grocery retailers",
      "tam": "$3B"
    },
    "vision_and_strategy": {
      "five_year_vision": "Become the MENA trade-finance backbone."
    }
  }
}

### Poll Evaluation Status — replace JOB_ID with value from response above
GET {{baseUrl}}/api/v1/evaluation/evaluate/status/JOB_ID_HERE

### Generate PDF Report from Evaluation Results
POST {{baseUrl}}/api/v1/evaluation/generate-report
Content-Type: application/json

{
  "weighted_score": 72,
  "company_name": "FinBoost",
  "team_report": { "score": 3.5, "summary": "Strong technical team." },
  "market_report": { "score": 4.5, "summary": "Large underserved MENA market." },
  "final_report": { "recommendation": "Proceed to Seed round." }
}


# ════════════════════════════════════════════════════════
# RECOMMENDATION   prefix: /api/v1  (no sub-prefix)
# ════════════════════════════════════════════════════════

### Get Strategic Recommendations
POST {{baseUrl}}/api/v1/recommend
Content-Type: application/json

{
  "raw_input": {
    "company_snapshot": {
      "company_name": "FinBoost",
      "industry": "Fintech",
      "current_stage": "Seed"
    }
  },
  "evaluation_output": {
    "stage": "Seed",
    "company_context": "A fintech startup in Egypt focusing on SME credit scoring",
    "scores": {
      "team":      { "score": 3.5, "description": "Strong technical team, weak on sales" },
      "problem":   { "score": 4.0, "description": "Well-validated problem with clear evidence" },
      "product":   { "score": 3.0, "description": "MVP launched, needs more features" },
      "market":    { "score": 4.5, "description": "Large underserved market in MENA" },
      "traction":  { "score": 2.5, "description": "Early revenue but high churn" },
      "gtm":       { "score": 2.0, "description": "No clear go-to-market strategy" },
      "economics": { "score": 3.0, "description": "Healthy margins but burn rate high" },
      "ops":       { "score": 2.5, "description": "No formal processes" },
      "vision":    { "score": 4.0, "description": "Bold MENA expansion vision" }
    }
  },
  "request_id": "test-001"
}

### Get Investor Subtags from Neo4j (recommendation router)
GET {{baseUrl}}/api/v1/investors/user123/subtags


# ════════════════════════════════════════════════════════
# MARKET RESEARCH   prefix: /api/v1/market-research
# ════════════════════════════════════════════════════════

### Run Full Market Research
POST {{baseUrl}}/api/v1/market-research/research
Content-Type: application/json

{
  "idea": "AI-powered credit scoring for SMEs",
  "problem": "SMEs in Egypt cannot access working capital from traditional banks due to lack of credit history.",
  "region": "Egypt"
}

### Validate a Startup Idea
POST {{baseUrl}}/api/v1/market-research/validate-idea
Content-Type: application/json

{
  "idea": "AI fitness tracking app for MENA",
  "problem": "People in MENA have no access to affordable personalized fitness coaching.",
  "region": "MENA"
}


# ════════════════════════════════════════════════════════
# SWOT GENERATION   prefix: /api/v1/swot
# ════════════════════════════════════════════════════════

### Generate SWOT Analysis
POST {{baseUrl}}/api/v1/swot/generate
Content-Type: application/json

{
  "idea_name": "FinBoost",
  "idea_description": "AI-powered credit scoring platform for Egyptian SMEs",
  "region": "MENA",
  "market_research": {
    "data": {
      "market_size": "$3B TAM in MENA SME lending",
      "competitors": ["Khazna", "Telda", "Paymob"],
      "trends": ["Digital banking adoption", "Open banking regulations"],
      "pain_points": ["No credit history for SMEs", "Long bank approval times"]
    }
  },
  "comment": "Focus on strengths vs traditional banks"
}


